{
	"Version": "2012-10-17",
	"Statement": [
		{
			"Sid": "AllowEC2DescribeActions",
			"Effect": "Allow",
			"Action": [
				"ec2:Describe*"
			],
			"Resource": [
				"*"
			]
		},
		{
			"Sid": "DenyInstanceCreateAndDelete",
			"Effect": "Deny",
			"Action": [
				"ec2:RunInstances",
				"ec2:TerminateInstances"
			],
			"Resource": [
				"*"
			]
		}
	]
}